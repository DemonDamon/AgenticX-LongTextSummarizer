# ============================================================
# 本地开发环境变量模板
# 使用方法：复制本文件为 .env.local，按需填写
#   cp .env.local.example .env.local
# .env.local 已在 .gitignore 中，不会被提交到 git
# ============================================================

# ---- 网站访问统计（Umami Analytics）----
# 用途：统计页面访问量、用户来源等数据（可选功能）
# 本地开发时留空即可，不影响任何核心功能
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# 如需启用统计，填写 Umami 服务地址和网站 ID，例如：
# VITE_ANALYTICS_ENDPOINT=https://analytics.your-domain.com
# VITE_ANALYTICS_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---- OAuth 登录（Manus OAuth）----
# 用途：用户登录功能（历史记录等需要登录的功能依赖此配置）
# 本地开发时留空，点击登录按钮会弹出提示说明
# 线上部署时由 Manus 平台自动注入，无需手动配置
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
